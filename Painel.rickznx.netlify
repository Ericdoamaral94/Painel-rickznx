<!DOCTYPE html>
<html lang="pt-br">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Rickznx Painel</title>

<link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@500&display=swap" rel="stylesheet">

<style>
body{
    margin:0;
    font-family:'Orbitron', sans-serif;
    background: radial-gradient(circle at top, #1a001f, #000);
    color:white;
    overflow:hidden;
}

.background{
    position:fixed;
    width:100%;
    height:100%;
    background: linear-gradient(180deg, rgba(128,0,255,0.1) 0%, rgba(0,0,0,1) 100%);
    animation: glow 5s infinite alternate;
}

@keyframes glow{
    from{filter:brightness(1);}
    to{filter:brightness(1.3);}
}

.panel{
    position:relative;
    margin:40px auto;
    width:380px;
    padding:25px;
    border-radius:20px;
    background:rgba(20,0,40,0.9);
    box-shadow:0 0 30px #a020f0;
}

h1{
    text-align:center;
    color:#bb66ff;
}

.option{
    margin:10px 0;
}

select, input[type=range]{
    width:100%;
    padding:8px;
    border-radius:10px;
    border:none;
    background:#220033;
    color:white;
}

button{
    width:100%;
    padding:15px;
    margin-top:15px;
    border:none;
    border-radius:15px;
    background:linear-gradient(45deg,#a020f0,#ff00ff);
    color:white;
    font-size:16px;
    cursor:pointer;
    transition:0.3s;
}

button:hover{
    transform:scale(1.05);
    box-shadow:0 0 20px #ff00ff;
}

.toggle{
    display:flex;
    justify-content:space-between;
    margin-top:10px;
}
</style>
</head>

<body>
<div class="background"></div>

<div class="panel">
<h1>Rickznx Painel</h1>

<div class="option"><input type="checkbox"> Aim 100%</div>
<div class="option"><input type="checkbox"> AimSmooth</div>
<div class="option"><input type="checkbox"> Precision</div>
<div class="option"><input type="checkbox"> Mira Estabelecida na Cabeça</div>

<label>FOV 20</label>
<input type="range" min="0" max="100" value="20">

<select>
<option>Auxílio Head</option>
<option>Auxílio Recoil</option>
<option>Auxílio Sensi</option>
<option>Auxílio Aimbot</option>
</select>

<select>
<option>Prioridade: Cabeça</option>
<option>Peito</option>
<option>HS Aimbot</option>
</select>

<div class="toggle">
<label><input type="radio" name="modo"> Ao Atirar</label>
<label><input type="radio" name="modo"> Ao Olhar</label>
</div>

<button onclick="instalar()">Instalar App de Treino</button>

<audio autoplay loop>
<source src="musica.mp3" type="audio/mpeg">
</audio>

</div>

<script>
function instalar(){
    alert("Download do App de Treino Rickznx iniciado!");
    window.location.href = "https://seulink.com/download";
}
</script>

</body>
</html><!DOCTYPE html>
<html lang="pt-br">
<head>
