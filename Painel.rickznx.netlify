    background:linear-gradient(45deg,#2b0040,#6a00ff);
}

h1{
    font-size:40px;
}

button{
    padding:15px 40px;
    font-size:18px;
    border:none;
    border-radius:20px;
    background:#bb00ff;
    color:white;
    cursor:pointer;
}

.section{
    padding:60px 20px;
}

.card{
    background:#1a001f;
    padding:20px;
    margin:20px;
    border-radius:15px;
}
</style>
</head>

<body>

<div class="hero">
<h1>Rickznx Painel</h1>
<p>O Melhor App de Treino de Mira</p>
<button onclick="window.location.href='index.html'">Baixar Agora</button>
</div>

<div class="section">
<div class="card">
<h2>Modo Treino Headshot</h2>
<p>Treine sua precisão com sistema avançado de simulação.</p>
</div>

<div class="card">
<h2>Configuração de Sensibilidade</h2>
<p>Ajuste seu estilo de jogo e melhore sua consistência.</p>
</div>

<div class="card">
<h2>Interface Futurista Roxa</h2>
<p>Visual gamer profissional 4K.</p>
</div>
</div>

</body>
</html>